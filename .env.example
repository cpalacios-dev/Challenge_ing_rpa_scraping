# ============================================================
# .env.example
# Plantilla de configuración. Copiar como ".env" y ajustar
# según el entorno (local / GCP). El archivo ".env" real NO
# debe versionarse (ver .gitignore).
# ============================================================

# ------------------------------------------------------------
# Entorno de ejecución
# ------------------------------------------------------------
# "development" para ejecución local, "production" para GCP.
# No cambia lógica por ahora, pero queda disponible para
# diferenciar comportamiento (ej. logs más verbosos en dev).
ENV=development

# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
# INFO es lo recomendado para operación normal.
LOG_LEVEL=INFO


# ------------------------------------------------------------
# Scraping - Banco Central de Chile
# ------------------------------------------------------------
# URL base desde donde se extraen UF, Dólar, Euro y UTM.
URL_BANCO_CENTRAL=https://www.bcentral.cl

# Tiempo máximo (en segundos) de espera para que la página cargue
# y los selectores aparezcan renderizados. Playwright lo convierte
# internamente a milisegundos.
TIMEOUT=15

# Número de reintentos ante timeouts de red transitorios durante
# la navegación inicial, antes de marcar todos los indicadores
# como "fallido". No se reintenta la búsqueda de selectores
# individuales (ver README, sección "Decisiones técnicas").
MAX_RETRIES=3


# ------------------------------------------------------------
# Persistencia / Storage
# ------------------------------------------------------------
# Motor de persistencia a usar: "json" o "sqlite".
# Permite cambiar de backend sin modificar código, por ejemplo
# usar JSON en local y SQLite (o Cloud SQL) en GCP.
STORAGE_BACKEND=json

# Ruta del archivo de salida cuando STORAGE_BACKEND=json
OUTPUT_FILE=src/output/indicadores.json

# Ruta del archivo de base de datos cuando STORAGE_BACKEND=sqlite
SQLITE_DB_PATH=src/output/indicadores.db


# ------------------------------------------------------------
# Notas de seguridad
# ------------------------------------------------------------
# Este proyecto no requiere credenciales en su forma actual
# (scraping de contenido público, sin autenticación).
#
# Si en el futuro se agregan credenciales (ej. una base de datos
# gestionada, un webhook de alertas), NO deben declararse aquí
# en texto plano para producción: usar Secret Manager en GCP o
# un gestor de secretos local equivalente. Esta plantilla es solo
# de referencia para variables de configuración no sensibles.
